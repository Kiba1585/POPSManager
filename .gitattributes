# ============================================
# POPSManager — .gitattributes
# Normaliza line endings a LF en todo el repo
# ============================================

# Default: normalizar a LF
* text=auto eol=lf

# Código fuente: siempre LF
*.cs        text eol=lf
*.xaml      text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.sln       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf
*.config    text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf

# Binarios: no tocar
*.exe       binary
*.dll       binary
*.png       binary
*.jpg       binary
*.ico       binary
*.bmp       binary
*.elf       binary
*.vcd       binary
*.iso       binary
*.zip       binary
