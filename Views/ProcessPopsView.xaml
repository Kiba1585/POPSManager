<UserControl x:Class="POPSManager.Views.ProcessPopsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:POPSManager.ViewModels"
             Background="{StaticResource Brush.Background}">

    <!-- ❌ Eliminado DataContext en XAML -->

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Procesar juegos"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   Margin="0 0 0 20"/>

        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Padding="20"
                Effect="{StaticResource ShadowDefault}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Carpeta con juegos (VCD / ISO)"
                               FontSize="16"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 6"/>
                    <TextBox Text="{Binding VcdPath, UpdateSourceTrigger=PropertyChanged}"
                             Height="32"
                             Background="{StaticResource Brush.PanelAlt}"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             BorderBrush="{StaticResource Brush.Border}"
                             BorderThickness="1"
                             Padding="6"/>
                </StackPanel>

                <Button Grid.Row="0" Grid.Column="1"
                        Content="Examinar"
                        Width="120" Height="32"
                        Margin="10 0 0 0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding BrowseVcdCommand}"/>

                <Border Grid.Row="1" Grid.ColumnSpan="2"
                        Style="{StaticResource Card}"
                        Margin="0 20 0 0"
                        Padding="10"
                        Background="{StaticResource Brush.PanelAlt}"
                        Effect="{StaticResource ShadowSoft}">
                    <StackPanel>
                        <TextBlock Text="Juegos detectados (PS1 / PS2)"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Margin="0 0 0 10"/>
                        <ListBox ItemsSource="{Binding Games}"
                                 Height="260"
                                 Background="{StaticResource Brush.Panel}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 BorderThickness="0"
                                 Padding="6"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Button Grid.Row="2"
                Content="Procesar juegos"
                Height="42" Width="220"
                HorizontalAlignment="Right"
                Margin="0 20 0 0"
                Style="{StaticResource PrimaryButton}"
                Command="{Binding ProcessCommand}"/>
    </Grid>
</UserControl>