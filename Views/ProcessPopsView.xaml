<UserControl x:Class="POPSManager.Views.ProcessPopsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Procesar POPS"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   Margin="0 0 0 20"/>

        <!-- Contenido -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Zona de arrastrar carpetas -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="2"
                    CornerRadius="10"
                    Background="{StaticResource Brush.PanelAlt}"
                    Padding="20"
                    AllowDrop="True"
                    Drop="DropFolder"
                    DragOver="DragOverFolder">

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">

                    <TextBlock Text="Arrastra aquí una carpeta con VCD"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               FontSize="16"
                               HorizontalAlignment="Center"/>

                    <Button Content="Seleccionar carpeta"
                            Width="200"
                            Height="40"
                            Style="{StaticResource PrimaryButton}"
                            Click="SelectFolder_Click"/>
                </StackPanel>

            </Border>

            <!-- Panel lateral de vista previa -->
            <Border Grid.Column="1"
                    Style="{StaticResource Card}"
                    Margin="20 0 0 0">

                <StackPanel Spacing="10">

                    <TextBlock Text="Vista previa"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <Border Background="{StaticResource Brush.Panel}"
                            Height="180"
                            CornerRadius="6"
                            HorizontalAlignment="Center"
                            Width="180">
                        <TextBlock Text="Sin carátula"
                                   Foreground="{StaticResource Brush.TextMuted}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Carpeta:"
                               Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBlock x:Name="PreviewFolder"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <TextBlock Text="Game ID:"
                               Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBlock x:Name="PreviewGameId"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <TextBlock Text="Región:"
                               Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBlock x:Name="PreviewRegion"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <Button Content="Procesar ahora"
                            Style="{StaticResource PrimaryButton}"
                            Height="40"
                            Margin="0 10 0 0"
                            Click="ProcessNow_Click"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</UserControl>
