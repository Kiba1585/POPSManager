<UserControl x:Class="POPSManager.Views.ProcessPopsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:POPSManager.ViewModels"
             Background="{StaticResource Brush.Background}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título y botón de refrescar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 10">
            <TextBlock Text="Gestor de Juegos"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       VerticalAlignment="Center"/>
            <Button Content="🔄 Refrescar"
                    Width="120" Height="32"
                    Style="{StaticResource SecondaryButton}"
                    Margin="20 0 0 0"
                    Command="{Binding RefreshGamesCommand}"
                    VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Listas de juegos -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ========================================================= -->
                <!--  JUEGOS DE PS1 -->
                <!-- ========================================================= -->
                <Border Background="#1E3A5F" CornerRadius="8" Margin="0 0 0 15" Padding="10"
                        Effect="{StaticResource ShadowSoft}">
                    <StackPanel>
                        <TextBlock Text="🎮 Juegos de PS1"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0 0 0 8"/>
                        <ListBox ItemsSource="{Binding Ps1Games}"
                                 SelectedItem="{Binding SelectedPs1Game}"
                                 Height="200"
                                 Background="{StaticResource Brush.Panel}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 BorderThickness="0"
                                 Padding="6"
                                 DisplayMemberPath="Name"/>
                    </StackPanel>
                </Border>

                <!-- ========================================================= -->
                <!--  JUEGOS DE PS2 -->
                <!-- ========================================================= -->
                <Border Background="#2F1E3A" CornerRadius="8" Margin="0 0 0 15" Padding="10"
                        Effect="{StaticResource ShadowSoft}">
                    <StackPanel>
                        <TextBlock Text="💿 Juegos de PS2"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0 0 0 8"/>
                        <ListBox ItemsSource="{Binding Ps2Games}"
                                 SelectedItem="{Binding SelectedPs2Game}"
                                 Height="200"
                                 Background="{StaticResource Brush.Panel}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 BorderThickness="0"
                                 Padding="6"
                                 DisplayMemberPath="Name"/>
                    </StackPanel>
                </Border>

                <!-- ========================================================= -->
                <!--  APLICACIONES (APPs) -->
                <!-- ========================================================= -->
                <Border Background="#3A2E1E" CornerRadius="8" Margin="0 0 0 15" Padding="10"
                        Effect="{StaticResource ShadowSoft}">
                    <StackPanel>
                        <TextBlock Text="⚙️ Aplicaciones (APPs)"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0 0 0 8"/>
                        <ListBox ItemsSource="{Binding AppsGames}"
                                 SelectedItem="{Binding SelectedAppsGame}"
                                 Height="200"
                                 Background="{StaticResource Brush.Panel}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 BorderThickness="0"
                                 Padding="6"
                                 DisplayMemberPath="Name"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Barra de acciones -->
        <Border Grid.Row="2"
                Background="{StaticResource Brush.Panel}"
                CornerRadius="8"
                Padding="15"
                Margin="0 15 0 0"
                Effect="{StaticResource ShadowSoft}">
            <WrapPanel Orientation="Horizontal">
                <Button Content="🎨 Descargar carátula"
                        Width="170" Height="40"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0 0 10 10"
                        Command="{Binding DownloadCoversCommand}"/>

                <Button Content="🧬 Generar ELF"
                        Width="150" Height="40"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0 0 10 10"
                        Command="{Binding GenerateElfCommand}"/>

                <Button Content="📋 Generar metadatos"
                        Width="170" Height="40"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0 0 10 10"
                        Command="{Binding GenerateMetadataCommand}"/>

                <Button Content="🎯 Generar cheats"
                        Width="160" Height="40"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0 0 10 10"
                        Command="{Binding GenerateCheatsCommand}"/>

                <Button Content="⚙️ Procesar seleccionado"
                        Width="190" Height="40"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0 0 10 10"
                        Command="{Binding ProcessSelectedCommand}"/>
            </WrapPanel>
        </Border>

    </Grid>
</UserControl>