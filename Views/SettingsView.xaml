<UserControl x:Class="POPSManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20">

            <!-- Título -->
            <TextBlock Text="Configuración"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0 0 0 20"/>

            <!-- ========================= -->
            <!--  SECCIÓN: RUTAS DE SALIDA -->
            <!-- ========================= -->
            <Border Style="{StaticResource Card}">
                <StackPanel>

                    <TextBlock Text="Rutas de salida"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 12"/>

                    <!-- POPS -->
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <TextBox x:Name="PopsPath"
                                 Width="400"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 Margin="0 0 10 0"/>

                        <Button Content="Cambiar"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                Click="ChangePopsPath_Click"/>
                    </StackPanel>

                    <!-- APPS -->
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="AppsPath"
                                 Width="400"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 Margin="0 0 10 0"/>

                        <Button Content="Cambiar"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                Click="ChangeAppsPath_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================= -->
            <!--  SECCIÓN: POPSTARTER.ELF -->
            <!-- ========================= -->
            <Border Style="{StaticResource Card}" Margin="0 20 0 0">
                <StackPanel>

                    <TextBlock Text="POPStarter"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 12"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="ElfPathBox"
                                 Width="400"
                                 IsReadOnly="True"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 Margin="0 0 10 0"/>

                        <Button Content="Seleccionar"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                Click="SelectElf_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================= -->
            <!--  SECCIÓN: OPCIONES GENERALES -->
            <!-- ========================= -->
            <Border Style="{StaticResource Card}" Margin="0 20 0 0">
                <StackPanel>

                    <TextBlock Text="Opciones generales"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 12"/>

                    <!-- Switch: Modo oscuro -->
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                        <ToggleButton x:Name="DarkModeToggle"
                                      Width="50"
                                      Height="26"
                                      Background="#444"
                                      BorderThickness="0"
                                      Margin="0 0 10 0">
                            <Ellipse Width="20" Height="20"
                                     Fill="White"
                                     Margin="3"/>
                        </ToggleButton>

                        <TextBlock Text="Modo oscuro"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                    <!-- Switch: Notificaciones -->
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="NotificationsToggle"
                                      Width="50"
                                      Height="26"
                                      Background="#444"
                                      BorderThickness="0"
                                      Margin="0 0 10 0">
                            <Ellipse Width="20" Height="20"
                                     Fill="White"
                                     Margin="3"/>
                        </ToggleButton>

                        <TextBlock Text="Notificaciones visuales"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================= -->
            <!--  SECCIÓN: INFORMACIÓN -->
            <!-- ========================= -->
            <Border Style="{StaticResource Card}" Margin="0 20 0 0">
                <StackPanel>

                    <TextBlock Text="Información"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 12"/>

                    <TextBlock Text="Versión: 1.0.0"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 6"/>

                    <TextBlock Text="Desarrollado por Raidel"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 12"/>

                    <Button Content="Abrir carpeta del programa"
                            Style="{StaticResource SecondaryButton}"
                            Width="220"
                            Click="OpenProgramFolder_Click"/>

                </StackPanel>
            </Border>

        </StackPanel>

    </ScrollViewer>
</UserControl>
