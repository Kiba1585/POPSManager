<UserControl x:Class="POPSManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  CanContentScroll="True">

        <StackPanel Margin="20">

            <!-- ========================================================= -->
            <!--  TÍTULO -->
            <!-- ========================================================= -->
            <TextBlock Text="Configuración"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0 0 0 20"/>

            <!-- ========================================================= -->
            <!--  SECCIÓN: RUTAS DE SALIDA -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    Effect="{StaticResource ShadowSoft}"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Rutas de salida"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 16"/>

                    <!-- POPS -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0 0 0 16">

                        <TextBox x:Name="PopsPath"
                                 Width="400"
                                 IsReadOnly="True"
                                 Background="{StaticResource Brush.PanelAlt}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 BorderBrush="{StaticResource Brush.Border}"
                                 BorderThickness="1"
                                 Padding="6"
                                 TextWrapping="NoWrap"
                                 Margin="0 0 10 0"/>

                        <Button Content="Cambiar"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                Click="ChangePopsPath_Click"/>
                    </StackPanel>

                    <!-- APPS -->
                    <StackPanel Orientation="Horizontal">

                        <TextBox x:Name="AppsPath"
                                 Width="400"
                                 IsReadOnly="True"
                                 Background="{StaticResource Brush.PanelAlt}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 BorderBrush="{StaticResource Brush.Border}"
                                 BorderThickness="1"
                                 Padding="6"
                                 TextWrapping="NoWrap"
                                 Margin="0 0 10 0"/>

                        <Button Content="Cambiar"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                Click="ChangeAppsPath_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================================================= -->
            <!--  SECCIÓN: POPSTARTER.ELF -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    Effect="{StaticResource ShadowSoft}"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="POPStarter"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 16"/>

                    <StackPanel Orientation="Horizontal">

                        <TextBox x:Name="ElfPathBox"
                                 Width="400"
                                 IsReadOnly="True"
                                 Background="{StaticResource Brush.PanelAlt}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 BorderBrush="{StaticResource Brush.Border}"
                                 BorderThickness="1"
                                 Padding="6"
                                 TextWrapping="NoWrap"
                                 Margin="0 0 10 0"/>

                        <Button Content="Seleccionar"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                Click="SelectElf_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================================================= -->
            <!--  SECCIÓN: OPCIONES GENERALES -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    Effect="{StaticResource ShadowSoft}"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Opciones generales"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 16"/>

                    <!-- Switch: Modo oscuro -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0 0 0 16">

                        <ToggleButton x:Name="DarkModeToggle"
                                      Width="50"
                                      Height="26"
                                      Style="{StaticResource ToggleSwitch}"
                                      Margin="0 0 10 0"/>

                        <TextBlock Text="Modo oscuro"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                    <!-- Switch: Notificaciones -->
                    <StackPanel Orientation="Horizontal">

                        <ToggleButton x:Name="NotificationsToggle"
                                      Width="50"
                                      Height="26"
                                      Style="{StaticResource ToggleSwitch}"
                                      Margin="0 0 10 0"/>

                        <TextBlock Text="Notificaciones visuales"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================================================= -->
            <!--  SECCIÓN: INFORMACIÓN -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    Effect="{StaticResource ShadowSoft}">

                <StackPanel>

                    <TextBlock Text="Información"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 10"/>

                    <TextBlock Text="Versión: 1.0.0"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 4"/>

                    <TextBlock Text="Desarrollado por Raidel"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 12"/>

                    <Button Content="Abrir carpeta del programa"
                            Style="{StaticResource SecondaryButton}"
                            Width="220"
                            Click="OpenProgramFolder_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>

    </ScrollViewer>
</UserControl>
