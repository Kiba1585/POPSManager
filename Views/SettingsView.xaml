<UserControl x:Class="POPSManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  CanContentScroll="True">

        <StackPanel Margin="20">

            <!-- ========================================================= -->
            <!--  SECCIÓN: OPCIONES GENERALES -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    Effect="{StaticResource ShadowSoft}"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Opciones generales"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 16"/>

                    <!-- Switch: Modo oscuro -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0 0 0 16">

                        <ToggleButton x:Name="DarkModeToggle"
                                      Width="50"
                                      Height="26"
                                      Style="{StaticResource ToggleSwitch}"
                                      Margin="0 0 10 0"
                                      Checked="DarkModeToggle_Checked"
                                      Unchecked="DarkModeToggle_Unchecked"/>

                        <TextBlock Text="Modo oscuro"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                    <!-- Switch: Notificaciones -->
                    <StackPanel Orientation="Horizontal">

                        <ToggleButton x:Name="NotificationsToggle"
                                      Width="50"
                                      Height="26"
                                      Style="{StaticResource ToggleSwitch}"
                                      Margin="0 0 10 0"
                                      Checked="NotificationsToggle_Checked"
                                      Unchecked="NotificationsToggle_Unchecked"/>

                        <TextBlock Text="Notificaciones visuales"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================================================= -->
            <!--  SECCIÓN: AUTOMATIZACIÓN INTELIGENTE -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    Effect="{StaticResource ShadowSoft}"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Automatización inteligente"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 16"/>

                    <!-- Modo global -->
                    <TextBlock Text="Modo global"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 8"/>

                    <StackPanel Margin="0 0 0 12">
                        <RadioButton x:Name="AutoModeAutomatic"
                                     Content="Automático (POPSManager hace todo por ti)"
                                     GroupName="AutomationMode"
                                     Checked="AutomationMode_Checked"
                                     Margin="0 0 0 4"/>

                        <RadioButton x:Name="AutoModeIntelligent"
                                     Content="Asistido (pregunta antes de cambios importantes)"
                                     GroupName="AutomationMode"
                                     Checked="AutomationMode_Checked"
                                     Margin="0 0 0 4"/>

                        <RadioButton x:Name="AutoModeManual"
                                     Content="Manual (tú decides cada acción)"
                                     GroupName="AutomationMode"
                                     Checked="AutomationMode_Checked"/>
                    </StackPanel>

                    <!-- Opciones por parte -->
                    <TextBlock Text="Opciones avanzadas"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 8"/>

                    <!-- Normalizar nombres -->
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                        <TextBlock Text="Normalizar nombres de juegos"
                                   Width="220"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                        <ComboBox x:Name="NormalizeNamesBehaviorBox"
                                  Width="160"
                                  SelectionChanged="NormalizeNamesBehaviorBox_SelectionChanged">
                            <ComboBoxItem Content="Automático" Tag="Automatico"/>
                            <ComboBoxItem Content="Preguntar" Tag="Preguntar"/>
                            <ComboBoxItem Content="Manual" Tag="Manual"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Agrupar multidisco -->
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                        <TextBlock Text="Agrupar juegos multidisco"
                                   Width="220"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                        <ComboBox x:Name="GroupMultiDiscBehaviorBox"
                                  Width="160"
                                  SelectionChanged="GroupMultiDiscBehaviorBox_SelectionChanged">
                            <ComboBoxItem Content="Automático" Tag="Automatico"/>
                            <ComboBoxItem Content="Preguntar" Tag="Preguntar"/>
                            <ComboBoxItem Content="Manual" Tag="Manual"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Descargar carátulas -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Descargar carátulas"
                                   Width="220"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                        <ComboBox x:Name="DownloadCoversBehaviorBox"
                                  Width="160"
                                  SelectionChanged="DownloadCoversBehaviorBox_SelectionChanged">
                            <ComboBoxItem Content="Automático" Tag="Automatico"/>
                            <ComboBoxItem Content="Preguntar" Tag="Preguntar"/>
                            <ComboBoxItem Content="Manual" Tag="Manual"/>
                        </ComboBox>
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>

    </ScrollViewer>
</UserControl>
