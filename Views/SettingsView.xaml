<UserControl x:Class="POPSManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:POPSManager.ViewModels"
             xmlns:automation="clr-namespace:POPSManager.Logic.Automation"
             Background="{StaticResource Brush.Background}">

    <UserControl.DataContext>
        <viewModels:SettingsViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="True">
        <StackPanel Margin="20">

            <!-- ========================================================= -->
            <!--  OPCIONES GENERALES -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}" Padding="20" Effect="{StaticResource ShadowSoft}" Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="Opciones generales"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 16"/>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                        <CheckBox IsChecked="{Binding DarkMode}" Margin="0 0 10 0"/>
                        <TextBlock Text="Modo oscuro"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                        <CheckBox IsChecked="{Binding NotificationsEnabled}" Margin="0 0 10 0"/>
                        <TextBlock Text="Notificaciones visuales"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                        <TextBlock Text="Idioma:"
                                   Width="120"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                        <ComboBox ItemsSource="{Binding Languages}"
                                  SelectedValue="{Binding SelectedLanguage}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="DisplayName"
                                  Width="160"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========================================================= -->
            <!--  RUTAS DE TRABAJO -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}" Padding="20" Effect="{StaticResource ShadowSoft}" Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="Rutas de trabajo"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 16"/>

                    <!-- Carpeta de origen -->
                    <TextBlock Text="Carpeta de origen (juegos BIN/CUE/ISO):"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 6"/>
                    <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                             Height="32"
                             Background="{StaticResource Brush.PanelAlt}"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             BorderBrush="{StaticResource Brush.Border}"
                             BorderThickness="1"
                             Padding="6"
                             Margin="0 0 0 6"/>
                    <Button Content="Seleccionar carpeta de origen"
                            Width="180" Height="32"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ChangeSourceFolderCommand}"
                            Margin="0 0 0 16"/>

                    <!-- Carpeta de destino -->
                    <TextBlock Text="Carpeta de destino (raíz OPL):"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 6"/>
                    <TextBox Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                             Height="32"
                             Background="{StaticResource Brush.PanelAlt}"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             BorderBrush="{StaticResource Brush.Border}"
                             BorderThickness="1"
                             Padding="6"
                             Margin="0 0 0 6"/>
                    <Button Content="Seleccionar carpeta de destino"
                            Width="180" Height="32"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ChangeDestinationFolderCommand}"
                            Margin="0 0 0 16"/>

                    <!-- Carpeta de ELFs -->
                    <TextBlock Text="Carpeta de ELFs (POPSTARTER.ELF, POPS2.ELF...):"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 6"/>
                    <TextBox Text="{Binding ElfFolderPath, UpdateSourceTrigger=PropertyChanged}"
                             Height="32"
                             Background="{StaticResource Brush.PanelAlt}"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             BorderBrush="{StaticResource Brush.Border}"
                             BorderThickness="1"
                             Padding="6"
                             Margin="0 0 0 6"/>
                    <Button Content="Seleccionar carpeta de ELFs"
                            Width="180" Height="32"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ChangeElfFolderCommand}"
                            Margin="0 0 0 16"/>

                    <!-- Procesar subcarpetas -->
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding ProcessSubfolders}" Margin="0 0 10 0"/>
                        <TextBlock Text="Procesar subcarpetas recursivamente"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========================================================= -->
            <!--  AUTOMATIZACIÓN INTELIGENTE -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}" Padding="20" Effect="{StaticResource ShadowSoft}" Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="Automatización inteligente"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 16"/>

                    <TextBlock Text="Modo global"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 8"/>

                    <StackPanel Margin="0 0 0 12">
                        <RadioButton Content="Automático (POPSManager hace todo por ti)"
                                     IsChecked="{Binding AutomationMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static automation:AutomationMode.Automatico}}"
                                     Margin="0 0 0 4"/>
                        <RadioButton Content="Asistido (pregunta antes de cambios importantes)"
                                     IsChecked="{Binding AutomationMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static automation:AutomationMode.Asistido}}"
                                     Margin="0 0 0 4"/>
                        <RadioButton Content="Manual (tú decides cada acción)"
                                     IsChecked="{Binding AutomationMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static automation:AutomationMode.Manual}}"/>
                    </StackPanel>

                    <TextBlock Text="Opciones avanzadas"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 8"/>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                        <TextBlock Text="Normalizar nombres de juegos"
                                   Width="220" VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                        <ComboBox SelectedItem="{Binding NormalizeNamesBehavior}"
                                  ItemsSource="{Binding Source={StaticResource AutoBehaviorValues}}"
                                  Width="160"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                        <TextBlock Text="Agrupar juegos multidisco"
                                   Width="220" VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                        <ComboBox SelectedItem="{Binding GroupMultiDiscBehavior}"
                                  ItemsSource="{Binding Source={StaticResource AutoBehaviorValues}}"
                                  Width="160"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                        <TextBlock Text="Descargar carátulas"
                                   Width="220" VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                        <ComboBox SelectedItem="{Binding DownloadCoversBehavior}"
                                  ItemsSource="{Binding Source={StaticResource AutoBehaviorValues}}"
                                  Width="160"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                        <TextBlock Text="Copiar archivos de idioma (LNG)"
                                   Width="220" VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                        <ComboBox SelectedItem="{Binding LngBehavior}"
                                  ItemsSource="{Binding Source={StaticResource AutoBehaviorValues}}"
                                  Width="160"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Copiar temas (THM)"
                                   Width="220" VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                        <ComboBox SelectedItem="{Binding ThmBehavior}"
                                  ItemsSource="{Binding Source={StaticResource AutoBehaviorValues}}"
                                  Width="160"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========================================================= -->
            <!--  RUTAS PERSONALIZADAS (LNG y THM) -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}" Padding="20" Effect="{StaticResource ShadowSoft}" Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="Rutas personalizadas"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0 0 0 16"/>

                    <TextBlock Text="Carpeta de idiomas (LNG):"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 6"/>
                    <TextBox Text="{Binding LngPath, UpdateSourceTrigger=PropertyChanged}"
                             Height="32"
                             Background="{StaticResource Brush.PanelAlt}"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             BorderBrush="{StaticResource Brush.Border}"
                             BorderThickness="1"
                             Padding="6"
                             Margin="0 0 0 6"/>
                    <Button Content="Seleccionar carpeta LNG"
                            Width="180"
                            Height="32"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ChangeLngPathCommand}"
                            Margin="0 0 0 16"/>

                    <TextBlock Text="Carpeta de temas (THM):"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0 0 0 6"/>
                    <TextBox Text="{Binding ThmPath, UpdateSourceTrigger=PropertyChanged}"
                             Height="32"
                             Background="{StaticResource Brush.PanelAlt}"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             BorderBrush="{StaticResource Brush.Border}"
                             BorderThickness="1"
                             Padding="6"
                             Margin="0 0 0 6"/>
                    <Button Content="Seleccionar carpeta THM"
                            Width="180"
                            Height="32"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ChangeThmPathCommand}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>