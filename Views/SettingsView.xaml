<UserControl x:Class="POPSManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20" Spacing="20">

            <!-- Título -->
            <TextBlock Text="Configuración"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>

            <!-- ========================= -->
            <!--  SECCIÓN: RUTAS DE SALIDA -->
            <!-- ========================= -->
            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="12">

                    <TextBlock Text="Rutas de salida"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <!-- POPS -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox x:Name="PopsPath"
                                 Width="400"
                                 Text="{Binding PopsFolder, Source={x:Static local:App.Services.Paths}}"
                                 Foreground="{StaticResource Brush.TextPrimary}"/>

                        <Button Content="Cambiar"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                Click="ChangePopsPath_Click"/>
                    </StackPanel>

                    <!-- APPS -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox x:Name="AppsPath"
                                 Width="400"
                                 Text="{Binding AppsFolder, Source={x:Static local:App.Services.Paths}}"
                                 Foreground="{StaticResource Brush.TextPrimary}"/>

                        <Button Content="Cambiar"
                                Style="{StaticResource SecondaryButton}"
                                Width="100"
                                Click="ChangeAppsPath_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================= -->
            <!--  SECCIÓN: OPCIONES GENERALES -->
            <!-- ========================= -->
            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="12">

                    <TextBlock Text="Opciones generales"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <!-- Switch: Modo oscuro -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ToggleButton x:Name="DarkModeToggle"
                                      Width="50"
                                      Height="26"
                                      Background="#444"
                                      BorderThickness="0"
                                      Checked="DarkModeToggle_Checked"
                                      Unchecked="DarkModeToggle_Unchecked">
                            <Ellipse Width="20" Height="20"
                                     Fill="White"
                                     Margin="3"/>
                        </ToggleButton>

                        <TextBlock Text="Modo oscuro"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                    <!-- Switch: Notificaciones -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ToggleButton x:Name="NotificationsToggle"
                                      Width="50"
                                      Height="26"
                                      Background="#444"
                                      BorderThickness="0"
                                      Checked="NotificationsToggle_Checked"
                                      Unchecked="NotificationsToggle_Unchecked">
                            <Ellipse Width="20" Height="20"
                                     Fill="White"
                                     Margin="3"/>
                        </ToggleButton>

                        <TextBlock Text="Notificaciones visuales"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================= -->
            <!--  SECCIÓN: INFORMACIÓN -->
            <!-- ========================= -->
            <Border Style="{StaticResource Card}">
                <StackPanel Spacing="12">

                    <TextBlock Text="Información"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <TextBlock Text="Versión: 1.0.0"
                               Foreground="{StaticResource Brush.TextSecondary}"/>

                    <TextBlock Text="Desarrollado por Raidel"
                               Foreground="{StaticResource Brush.TextSecondary}"/>

                    <Button Content="Abrir carpeta del programa"
                            Style="{StaticResource SecondaryButton}"
                            Width="220"
                            Click="OpenProgramFolder_Click"/>

                </StackPanel>
            </Border>

        </StackPanel>

    </ScrollViewer>
</UserControl>
