<UserControl x:Class="POPSManager.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:POPSManager.Controls"
             Background="{StaticResource Brush.Background}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="20">

            <!-- ========================================================= -->
            <!--  TÍTULO -->
            <!-- ========================================================= -->
            <TextBlock Text="Dashboard"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>

            <!-- ========================================================= -->
            <!--  TARJETAS DE ESTADÍSTICAS -->
            <!-- ========================================================= -->
            <UniformGrid Columns="3"
                         HorizontalAlignment="Stretch"
                         Margin="0 0 0 10">

                <!-- Juegos procesados -->
                <Border Style="{StaticResource Card}"
                        Margin="10"
                        Effect="{StaticResource ShadowDefault}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Juegos procesados"
                                   FontSize="16"
                                   Foreground="{StaticResource Brush.TextSecondary}"/>
                        <TextBlock x:Name="ProcessedCount"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Accent}"/>
                    </StackPanel>
                </Border>

                <!-- Archivos pendientes -->
                <Border Style="{StaticResource Card}"
                        Margin="10"
                        Effect="{StaticResource ShadowDefault}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Archivos pendientes"
                                   FontSize="16"
                                   Foreground="{StaticResource Brush.TextSecondary}"/>
                        <TextBlock x:Name="PendingCount"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Warning}"/>
                    </StackPanel>
                </Border>

                <!-- Errores recientes -->
                <Border Style="{StaticResource Card}"
                        Margin="10"
                        Effect="{StaticResource ShadowDefault}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Errores recientes"
                                   FontSize="16"
                                   Foreground="{StaticResource Brush.TextSecondary}"/>
                        <TextBlock x:Name="ErrorCount"
                                   Text="0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Error}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- ========================================================= -->
            <!--  ACCIONES RÁPIDAS -->
            <!-- ========================================================= -->
            <StackPanel Spacing="10">
                <TextBlock Text="Acciones rápidas"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"/>

                <StackPanel Orientation="Horizontal" Spacing="20">

                    <Button Content="Convertir juegos"
                            Width="180"
                            Height="42"
                            Style="{StaticResource PrimaryButton}"
                            Click="OpenConvert_Click"/>

                    <Button Content="Procesar POPS"
                            Width="180"
                            Height="42"
                            Style="{StaticResource PrimaryButton}"
                            Click="OpenProcessPops_Click"/>

                    <Button Content="Abrir carpeta raíz"
                            Width="180"
                            Height="42"
                            Style="{StaticResource SecondaryButton}"
                            Click="OpenRootFolder_Click"/>

                    <Button Content="Abrir POPSTARTER.ELF"
                            Width="180"
                            Height="42"
                            Style="{StaticResource SecondaryButton}"
                            Click="OpenElfFolder_Click"/>

                </StackPanel>
            </StackPanel>

            <!-- ========================================================= -->
            <!--  CONFIGURACIÓN DE RUTAS -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}"
                    Effect="{StaticResource ShadowSoft}">
                <StackPanel Spacing="16">

                    <TextBlock Text="Configuración de rutas"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <!-- Ruta raíz -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Ruta raíz de destino:"
                                   FontSize="14"
                                   Foreground="{StaticResource Brush.TextSecondary}"/>

                        <TextBox x:Name="RootPath"
                                 Height="32"
                                 Background="{StaticResource Brush.PanelAlt}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 BorderBrush="{StaticResource Brush.Border}"
                                 BorderThickness="1"
                                 Padding="6"/>

                        <Button Content="Cambiar"
                                Width="120"
                                Height="32"
                                Style="{StaticResource PrimaryButton}"
                                Click="ChangeRootPath_Click"/>
                    </StackPanel>

                    <!-- ELF personalizado -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="POPSTARTER.ELF personalizado:"
                                   FontSize="14"
                                   Foreground="{StaticResource Brush.TextSecondary}"/>

                        <TextBox x:Name="ElfPath"
                                 Height="32"
                                 Background="{StaticResource Brush.PanelAlt}"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 BorderBrush="{StaticResource Brush.Border}"
                                 BorderThickness="1"
                                 Padding="6"/>

                        <Button Content="Seleccionar ELF"
                                Width="150"
                                Height="32"
                                Style="{StaticResource SecondaryButton}"
                                Click="SelectElf_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ========================================================= -->
            <!--  INFORMACIÓN DEL SISTEMA -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}"
                    Effect="{StaticResource ShadowSoft}">
                <StackPanel Spacing="10">

                    <TextBlock Text="Información del sistema"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <TextBlock x:Name="SystemInfo"
                               Text="Cargando..."
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"/>
                </StackPanel>
            </Border>

            <!-- ========================================================= -->
            <!--  REGISTRO DE ACTIVIDAD -->
            <!-- ========================================================= -->
            <Border Style="{StaticResource Card}"
                    Effect="{StaticResource ShadowSoft}">
                <StackPanel Spacing="10">

                    <TextBlock Text="Registro de actividad"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <local:LogsPanel/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
