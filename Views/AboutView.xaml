<UserControl x:Class="POPSManager.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:POPSManager.ViewModels"
             Background="{StaticResource Brush.Background}">

    <UserControl.DataContext>
        <viewModels:AboutViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Acerca de"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   Margin="0 0 0 20"/>

        <!-- Contenido -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Padding="30"
                Width="600"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Effect="{StaticResource ShadowSoft}">

            <StackPanel HorizontalAlignment="Center">

                <!-- Logo opcional -->
                <Ellipse Width="100" Height="100"
                         Fill="{StaticResource Brush.Accent}"
                         Opacity="0.15"
                         Stroke="#888"
                         StrokeThickness="1"
                         Margin="0 0 0 20"/>

                <!-- Nombre del programa -->
                <TextBlock Text="POPSManager"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <!-- Versión -->
                <TextBlock Text="Versión 1.0.0"
                           FontSize="16"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <!-- Descripción -->
                <TextBlock Text="Herramienta profesional para convertir, procesar y gestionar juegos POPS para PlayStation 2."
                           FontSize="14"
                           Foreground="{StaticResource Brush.TextMuted}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Width="480"
                           Margin="0 0 0 20"/>

                <Separator Margin="0 10"/>

                <!-- Créditos -->
                <StackPanel HorizontalAlignment="Center"
                            Margin="0 10">
                    <TextBlock Text="Desarrollado por:"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 4"/>
                    <TextBlock Text="Raidel"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Separator Margin="0 10"/>

                <!-- Enlaces -->
                <StackPanel HorizontalAlignment="Center"
                            Margin="0 10">
                    <Button Content="Repositorio en GitHub"
                            Style="{StaticResource SecondaryButton}"
                            Width="200"
                            Margin="0 0 0 10"
                            Command="{Binding OpenGitHubCommand}"/>

                    <Button Content="Página del proyecto"
                            Style="{StaticResource SecondaryButton}"
                            Width="200"
                            Command="{Binding OpenWebsiteCommand}"/>
                </StackPanel>

                <Separator Margin="0 10"/>

                <!-- Derechos -->
                <TextBlock Text="© 2026 Raidel — Todos los derechos reservados."
                           FontSize="12"
                           Foreground="{StaticResource Brush.TextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0 10 0 0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>