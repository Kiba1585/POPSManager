<UserControl x:Class="POPSManager.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Background}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Acerca de"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   Margin="0 0 0 20"/>

        <!-- Contenido -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Width="600">

            <StackPanel Spacing="20"
                        HorizontalAlignment="Center">

                <!-- Logo opcional -->
                <Ellipse Width="100" Height="100"
                         Fill="{StaticResource Brush.Accent}"
                         Opacity="0.15">
                    <Ellipse.Stroke>
                        <SolidColorBrush Color="#888"/>
                    </Ellipse.Stroke>
                </Ellipse>

                <!-- Nombre del programa -->
                <TextBlock Text="POPSManager"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           HorizontalAlignment="Center"/>

                <!-- Versión -->
                <TextBlock Text="Versión 1.0.0"
                           FontSize="16"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           HorizontalAlignment="Center"/>

                <!-- Descripción -->
                <TextBlock Text="Herramienta profesional para convertir, procesar y gestionar juegos POPS para PlayStation 2."
                           FontSize="14"
                           Foreground="{StaticResource Brush.TextMuted}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Width="480"/>

                <!-- Línea divisoria -->
                <Separator Margin="0 10"/>

                <!-- Créditos -->
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="Desarrollado por:"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Raidel"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Línea divisoria -->
                <Separator Margin="0 10"/>

                <!-- Enlaces -->
                <StackPanel Spacing="10" HorizontalAlignment="Center">

                    <Button Content="Repositorio en GitHub"
                            Style="{StaticResource SecondaryButton}"
                            Width="200"
                            Click="OpenGitHub_Click"/>

                    <Button Content="Página del proyecto"
                            Style="{StaticResource SecondaryButton}"
                            Width="200"
                            Click="OpenWebsite_Click"/>

                </StackPanel>

                <!-- Línea divisoria -->
                <Separator Margin="0 10"/>

                <!-- Derechos -->
                <TextBlock Text="© 2026 Raidel — Todos los derechos reservados."
                           FontSize="12"
                           Foreground="{StaticResource Brush.TextMuted}"
                           HorizontalAlignment="Center"/>

            </StackPanel>

        </Border>

    </Grid>
</UserControl>
