<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================================================= -->
    <!--  PALETA DE COLORES (MODO OSCURO) -->
    <!-- ========================================================= -->

    <SolidColorBrush x:Key="Brush.Background" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Brush.Panel" Color="#252525"/>
    <SolidColorBrush x:Key="Brush.PanelAlt" Color="#2D2D2D"/>

    <SolidColorBrush x:Key="Brush.Border" Color="#3A3A3A"/>

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#888888"/>

    <SolidColorBrush x:Key="Brush.Accent" Color="#4CC2FF"/>
    <SolidColorBrush x:Key="Brush.AccentDark" Color="#2FA0D8"/>

    <SolidColorBrush x:Key="Brush.Success" Color="#4CAF50"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="#FFB300"/>
    <SolidColorBrush x:Key="Brush.Error" Color="#E53935"/>


    <!-- ========================================================= -->
    <!--  TIPOGRAFÍA GLOBAL -->
    <!-- ========================================================= -->

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
    </Style>


    <!-- ========================================================= -->
    <!--  BOTONES -->
    <!-- ========================================================= -->

    <!-- PRIMARIO -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Accent}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="10 6"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.AccentDark}"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!-- SECUNDARIO -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.PanelAlt}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        <Setter Property="Padding" Value="10 6"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#3A3A3A"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!-- PELIGRO -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource Brush.Error}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Error}"/>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#B71C1C"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!-- ========================================================= -->
    <!--  CARDS -->
    <!-- ========================================================= -->

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Panel}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>


    <!-- ========================================================= -->
    <!--  TEXTBOX -->
    <!-- ========================================================= -->

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Brush.PanelAlt}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="CaretBrush" Value="White"/>
    </Style>


    <!-- ========================================================= -->
    <!--  SCROLLBAR -->
    <!-- ========================================================= -->

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="Foreground" Value="#444"/>
    </Style>

</ResourceDictionary>
