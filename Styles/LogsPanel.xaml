<UserControl x:Class="POPSManager.Controls.LogsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Panel}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Registro de actividad"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   Margin="10 10 10 5"/>

        <!-- Contenedor del log -->
        <Border Grid.Row="1"
                Margin="10"
                Background="{StaticResource Brush.PanelAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">

            <ScrollViewer x:Name="ScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel x:Name="LogStack"
                            Orientation="Vertical"
                            Spacing="4"/>

            </ScrollViewer>

        </Border>

    </Grid>
</UserControl>
