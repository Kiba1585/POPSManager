<UserControl x:Class="POPSManager.Controls.ProgressPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Height="120"
             Width="320">

    <Border Background="{StaticResource Brush.PanelAlt}"
            CornerRadius="10"
            Padding="15"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            Effect="{StaticResource ShadowDefault}">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Text="Progreso"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>

            <!-- Texto de estado -->
            <TextBlock x:Name="StatusText"
                       Grid.Row="1"
                       Margin="0 8 0 10"
                       FontSize="14"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       Text="Esperando..."/>

            <!-- Barra + Spinner -->
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <!-- Barra de progreso -->
                <ProgressBar x:Name="ProgressBarControl"
                             Grid.Column="0"
                             Height="14"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Foreground="{StaticResource Brush.Accent}"
                             Background="#333"
                             BorderThickness="0"/>

                <!-- Spinner -->
                <Grid Grid.Column="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">

                    <Ellipse Width="18" Height="18"
                             Stroke="{StaticResource Brush.Accent}"
                             StrokeThickness="3"
                             Opacity="0.8">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                </Grid>

            </Grid>

        </Grid>

    </Border>
</UserControl>
