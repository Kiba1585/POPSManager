<UserControl x:Class="POPSManager.Controls.LogsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brush.Panel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Registro de actividad"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   Margin="10 10 10 5"/>

        <!-- Contenedor del log -->
        <Border Grid.Row="1"
                Margin="10"
                Background="{StaticResource Brush.PanelAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">

            <ScrollViewer x:Name="ScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <ItemsControl x:Name="LogItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0 2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icono según severidad -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Icon}"
                                           FontSize="14"
                                           VerticalAlignment="Top"
                                           Margin="0 2 0 0"/>

                                <!-- Mensaje con color según severidad -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Message}"
                                           Foreground="{Binding Color}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Top"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </ScrollViewer>

        </Border>

    </Grid>
</UserControl>