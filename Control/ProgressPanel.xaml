<UserControl x:Class="POPSManager.Controls.ProgressPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="120" Width="300">

    <Grid Margin="10">
        <StackPanel>

            <!-- Texto de estado -->
            <TextBlock x:Name="StatusTextBlock"
                       Text="Procesando..."
                       FontSize="14"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Center"/>

            <!-- Barra de progreso -->
            <ProgressBar x:Name="ProgressBarControl"
                         Height="20"
                         Minimum="0"
                         Maximum="100"/>

            <!-- Spinner -->
            <Grid Width="40" Height="40" Margin="0,10,0,0" HorizontalAlignment="Center">
                <Ellipse Width="40" Height="40"
                         Stroke="Gray"
                         StrokeThickness="4">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" CenterX="20" CenterY="20"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Grid>

        </StackPanel>
    </Grid>
</UserControl>