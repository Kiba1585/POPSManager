using System;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;
using POPSManager.Views;

namespace POPSManager
{
    public partial class MainWindow : Window
    {
        public MainWindow()
        {
            InitializeComponent();

            // Cargar vista inicial
            LoadView(new Dashboard());
        }

        // Método público para cargar vistas
        public void LoadView(UserControl view)
        {
            MainContent.Children.Clear();
            MainContent.Children.Add(view);
        }

        // Acceso seguro a App.Services
        private AppServices Services => ((App)Application.Current).Services;

        // ============================
        // EVENTOS DEL SIDEBAR
        // ============================

        private void Dashboard_Click(object sender, RoutedEventArgs e)
        {
            LoadView(new Dashboard());
            Services.Log("Vista: Dashboard");
        }

        private void Convert_Click(object sender, RoutedEventArgs e)
        {
            LoadView(new ConvertView());
            Services.Log("Vista: Convertir juegos");
        }

        private void ProcessPops_Click(object sender, RoutedEventArgs e)
        {
            LoadView(new ProcessPopsView());
            Services.Log("Vista: Procesar POPS");
        }

        private void Settings_Click(object sender, RoutedEventArgs e)
        {
            LoadView(new SettingsView());
            Services.Log("Vista: Configuración");
        }

        private void About_Click(object sender, RoutedEventArgs e)
        {
            LoadView(new AboutView());
            Services.Log("Vista: Acerca de");
        }

        // ============================
        // DRAG & DROP
        // ============================

        private void Window_DragOver(object sender, DragEventArgs e)
        {
            e.Effects = DragDropEffects.Copy;
            e.Handled = true;
        }

        private void Window_Drop(object sender, DragEventArgs e)
        {
            if (!e.Data.GetDataPresent(DataFormats.FileDrop))
                return;

            string[] files = (string[])e.Data.GetData(DataFormats.FileDrop);

            if (files.Length > 0)
            {
                Services.Log($"Archivo arrastrado: {files[0]}");
            }
        }
    }
}
