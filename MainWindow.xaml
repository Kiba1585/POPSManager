<Window x:Class="POPSManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:POPSManager.Controls"
        Title="POPSManager"
        Width="1200"
        Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}">

    <!-- ========================= -->
    <!--  RECURSOS (THEME + STYLES) -->
    <!-- ========================= -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Theme.xaml"/>
                <ResourceDictionary Source="Styles/SidebarStyles.xaml"/>
                <ResourceDictionary Source="Styles/Toasts.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>


    <Grid>

        <!-- ========================= -->
        <!--  DEFINICIÓN DE FILAS Y COLUMNAS -->
        <!-- ========================= -->
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Contenido -->
            <RowDefinition Height="28"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Panel principal -->
        </Grid.ColumnDefinitions>


        <!-- ========================= -->
        <!--  HEADER SUPERIOR -->
        <!-- ========================= -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource Brush.Panel}"
                Padding="12"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">

            <DockPanel>

                <!-- Logo + Nombre -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="POPSManager"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Botones de la derecha -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Spacing="12">

                    <Button Content="⚙"
                            Width="32" Height="32"
                            Style="{StaticResource SecondaryButton}"/>

                    <Button Content="❔"
                            Width="32" Height="32"
                            Style="{StaticResource SecondaryButton}"/>

                </StackPanel>

            </DockPanel>
        </Border>


        <!-- ========================= -->
        <!--  SIDEBAR IZQUIERDO -->
        <!-- ========================= -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">

            <StackPanel Margin="10" Spacing="6">

                <TextBlock Text="Menú"
                           Foreground="{StaticResource Brush.TextMuted}"
                           FontSize="14"
                           Margin="4 0 0 8"/>

                <!-- Botones del menú -->
                <Button Content="Dashboard"
                        Style="{StaticResource SidebarButtonStyle}"/>

                <Button Content="Convertir juegos"
                        Style="{StaticResource SidebarButtonStyle}"/>

                <Button Content="Procesar POPS"
                        Style="{StaticResource SidebarButtonStyle}"/>

                <Button Content="Configuración"
                        Style="{StaticResource SidebarButtonStyle}"/>

                <Button Content="Acerca de"
                        Style="{StaticResource SidebarButtonStyle}"/>

            </StackPanel>
        </Border>


        <!-- ========================= -->
        <!--  PANEL PRINCIPAL -->
        <!-- ========================= -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Text="Procesar juegos"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0 0 0 20"/>

            <!-- Contenido principal -->
            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Zona de arrastrar archivos -->
                <Border Grid.Column="0"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Background="{StaticResource Brush.PanelAlt}"
                        Padding="20"
                        AllowDrop="True">

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10">

                        <TextBlock Text="Arrastra aquí tus BIN / CUE / ISO / VCD"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>

                        <Button Content="Seleccionar archivos"
                                Width="180"
                                Height="40"
                                Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>

                </Border>

                <!-- Panel lateral de vista previa -->
                <Border Grid.Column="1"
                        Background="{StaticResource Brush.PanelAlt}"
                        CornerRadius="10"
                        Padding="15"
                        Margin="20 0 0 0"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1">

                    <StackPanel Spacing="10">

                        <TextBlock Text="Vista previa"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                        <Border Background="{StaticResource Brush.Panel}"
                                Height="180"
                                CornerRadius="6"
                                HorizontalAlignment="Center"
                                Width="180">
                            <TextBlock Text="Sin carátula"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Nombre:"
                                   Foreground="{StaticResource Brush.TextMuted}"/>
                        <TextBlock x:Name="PreviewName"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                        <TextBlock Text="Game ID:"
                                   Foreground="{StaticResource Brush.TextMuted}"/>
                        <TextBlock x:Name="PreviewGameId"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                        <TextBlock Text="Región:"
                                   Foreground="{StaticResource Brush.TextMuted}"/>
                        <TextBlock x:Name="PreviewRegion"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                        <TextBlock Text="Tipo:"
                                   Foreground="{StaticResource Brush.TextMuted}"/>
                        <TextBlock x:Name="PreviewType"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>


        <!-- ========================= -->
        <!--  STATUS BAR INFERIOR -->
        <!-- ========================= -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1,1,0,0"
                Padding="10 0">

            <DockPanel>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            Spacing="10">

                    <TextBlock x:Name="StatusText"
                               Text="Listo"
                               Foreground="{StaticResource Brush.TextSecondary}"/>

                    <TextBlock Text="●"
                               Foreground="{StaticResource Brush.Accent}"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="Ver logs"
                        DockPanel.Dock="Right"
                        Style="{StaticResource SecondaryButton}"
                        Width="80"
                        Height="22"/>
            </DockPanel>

        </Border>


        <!-- ========================= -->
        <!--  ÁREA DE NOTIFICACIONES -->
        <!-- ========================= -->
        <StackPanel x:Name="NotificationArea"
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Top"
                    Margin="0 60 0 0"
                    IsHitTestVisible="False"/>

    </Grid>
</Window>
