<Window x:Class="POPSManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POPS Manager - Raidel Edition"
        Height="600" Width="900"
        Background="#1E1E1E"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="POPS Manager"
                   FontSize="28"
                   Foreground="White"
                   FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 0 0 20">
            <Button Content="Seleccionar carpeta POPS"
                    Width="220" Height="35"
                    Click="SelectPOPS_Click"/>
            <TextBlock x:Name="POPSPath"
                       Text="No seleccionada"
                       Foreground="LightGray"
                       Margin="15 0 0 0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 0 0 20">
            <Button Content="Seleccionar carpeta APPS"
                    Width="220" Height="35"
                    Click="SelectAPPS_Click"/>
            <TextBlock x:Name="APPSPath"
                       Text="No seleccionada"
                       Foreground="LightGray"
                       Margin="15 0 0 0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Progreso:"
                       Foreground="White"
                       FontSize="16"
                       Margin="0 0 0 10"/>

            <ProgressBar x:Name="MainProgress"
                         Height="25"
                         Minimum="0" Maximum="100"
                         Value="0"/>

            <TextBlock x:Name="ProgressText"
                       Text="0%"
                       Foreground="LightGray"
                       Margin="0 5 0 15"/>

            <TextBlock x:Name="Spinner"
                       Text=""
                       Foreground="LightGreen"
                       FontSize="20"
                       Margin="0 0 0 15"/>

            <TextBox x:Name="LogBox"
                     Background="#111"
                     Foreground="LightGray"
                     FontFamily="Consolas"
                     FontSize="14"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     Height="250"/>
        </StackPanel>

        <Button Grid.Row="4"
                Content="Procesar juegos"
                Height="40"
                FontSize="16"
                Click="Process_Click"/>
    </Grid>
</Window>
