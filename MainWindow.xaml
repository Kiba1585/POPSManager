<Window x:Class="POPSManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:POPSManager.Controls"
        xmlns:views="clr-namespace:POPSManager.Views"
        Title="POPSManager"
        Width="1200"
        Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Theme.xaml"/>
                <ResourceDictionary Source="Styles/SidebarStyles.xaml"/>
                <ResourceDictionary Source="Styles/Toasts.xaml"/>
                <ResourceDictionary Source="Styles/Shadows.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource Brush.Panel}"
                Padding="12"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">

            <DockPanel>

                <TextBlock Text="POPSManager"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right">

                    <Button Content="⚙"
                            Width="32" Height="32"
                            Margin="0 0 12 0"
                            Style="{StaticResource SecondaryButton}"
                            Click="Settings_Click"/>

                    <Button Content="❔"
                            Width="32" Height="32"
                            Style="{StaticResource SecondaryButton}"
                            Click="About_Click"/>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- SIDEBAR -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">

            <StackPanel Margin="10">

                <TextBlock Text="Menú"
                           Foreground="{StaticResource Brush.TextMuted}"
                           FontSize="14"
                           Margin="4 0 0 8"/>

                <Button Content="Dashboard"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0 0 0 6"
                        Click="Dashboard_Click"/>

                <Button Content="Convertir juegos"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0 0 0 6"
                        Click="Convert_Click"/>

                <Button Content="Procesar POPS"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0 0 0 6"
                        Click="ProcessPops_Click"/>

                <Button Content="Configuración"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0 0 0 6"
                        Click="Settings_Click"/>

                <Button Content="Acerca de"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="About_Click"/>

            </StackPanel>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="20" x:Name="MainContent"/>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1,1,0,0"
                Padding="10 0">

            <DockPanel>
                <TextBlock x:Name="StatusText"
                           Text="Listo"
                           Foreground="{StaticResource Brush.TextSecondary}"/>
            </DockPanel>

        </Border>

        <!-- NOTIFICACIONES -->
        <StackPanel x:Name="NotificationArea"
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Top"
                    Margin="0 60 0 0"
                    IsHitTestVisible="False"/>

        <!-- PROGRESS PANEL -->
        <controls:ProgressPanel x:Name="ProgressPanelControl"
                                Grid.Row="1"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0 10 10 0"
                                Visibility="Collapsed"/>

    </Grid>
</Window>
