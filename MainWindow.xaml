<Window x:Class="POPSManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:POPSManager.Controls"
        xmlns:views="clr-namespace:POPSManager.Views"
        Title="POPSManager"
        Width="1200"
        Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}">

    <!-- ========================= -->
    <!--  RECURSOS GLOBALES -->
    <!-- ========================= -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Theme.xaml"/>
                <ResourceDictionary Source="Styles/SidebarStyles.xaml"/>
                <ResourceDictionary Source="Styles/Toasts.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>


    <Grid>

        <!-- ========================= -->
        <!--  DEFINICIÓN DE FILAS Y COLUMNAS -->
        <!-- ========================= -->
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Contenido -->
            <RowDefinition Height="28"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Panel principal -->
        </Grid.ColumnDefinitions>


        <!-- ========================= -->
        <!--  HEADER SUPERIOR -->
        <!-- ========================= -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource Brush.Panel}"
                Padding="12"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">

            <DockPanel>

                <!-- Logo + Nombre -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="POPSManager"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Botones de la derecha -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Spacing="12">

                    <Button Content="⚙"
                            Width="32" Height="32"
                            Style="{StaticResource SecondaryButton}"
                            Click="Settings_Click"/>

                    <Button Content="❔"
                            Width="32" Height="32"
                            Style="{StaticResource SecondaryButton}"
                            Click="About_Click"/>

                </StackPanel>

            </DockPanel>
        </Border>


        <!-- ========================= -->
        <!--  SIDEBAR IZQUIERDO -->
        <!-- ========================= -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">

            <StackPanel Margin="10" Spacing="6">

                <TextBlock Text="Menú"
                           Foreground="{StaticResource Brush.TextMuted}"
                           FontSize="14"
                           Margin="4 0 0 8"/>

                <!-- Botones del menú -->
                <Button Content="Dashboard"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="Dashboard_Click"/>

                <Button Content="Convertir juegos"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="Convert_Click"/>

                <Button Content="Procesar POPS"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="ProcessPops_Click"/>

                <Button Content="Configuración"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="Settings_Click"/>

                <Button Content="Acerca de"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="About_Click"/>

            </StackPanel>
        </Border>


        <!-- ========================= -->
        <!--  CONTENEDOR DE VISTAS -->
        <!-- ========================= -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="20" x:Name="MainContent"/>


        <!-- ========================= -->
        <!--  STATUS BAR INFERIOR -->
        <!-- ========================= -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1,1,0,0"
                Padding="10 0">

            <DockPanel>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            Spacing="10">

                    <TextBlock x:Name="StatusText"
                               Text="Listo"
                               Foreground="{StaticResource Brush.TextSecondary}"/>

                    <TextBlock Text="●"
                               Foreground="{StaticResource Brush.Accent}"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>

            </DockPanel>

        </Border>


        <!-- ========================= -->
        <!--  ÁREA DE NOTIFICACIONES -->
        <!-- ========================= -->
        <StackPanel x:Name="NotificationArea"
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Top"
                    Margin="0 60 0 0"
                    IsHitTestVisible="False"/>


        <!-- ========================= -->
        <!--  PANEL DE PROGRESO GLOBAL -->
        <!-- ========================= -->
        <controls:ProgressPanel x:Name="ProgressPanelControl"
                                Grid.Row="1"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0 10 10 0"
                                Visibility="Collapsed"/>

    </Grid>
</Window>
