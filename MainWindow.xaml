<Window x:Class="POPSManager."
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POPSManager"
        Width="1200"
        Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid>

        <!-- ========================= -->
        <!--  DEFINICIÓN DE FILAS Y COLUMNAS -->
        <!-- ========================= -->
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Contenido -->
            <RowDefinition Height="28"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Panel principal -->
        </Grid.ColumnDefinitions>


        <!-- ========================= -->
        <!--  HEADER SUPERIOR -->
        <!-- ========================= -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#252526"
                Padding="12"
                BorderBrush="#333"
                BorderThickness="0,0,0,1">

            <DockPanel>

                <!-- Logo + Nombre -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="POPSManager"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Botones de la derecha -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Spacing="12">

                    <Button Content="⚙"
                            Width="32" Height="32"
                            Background="#333"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <Button Content="❔"
                            Width="32" Height="32"
                            Background="#333"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>

                </StackPanel>

            </DockPanel>
        </Border>


        <!-- ========================= -->
        <!--  SIDEBAR IZQUIERDO -->
        <!-- ========================= -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="#252526"
                BorderBrush="#333"
                BorderThickness="0,0,1,0">

            <StackPanel Margin="10" Spacing="6">

                <TextBlock Text="Menú"
                           Foreground="#AAA"
                           FontSize="14"
                           Margin="4 0 0 8"/>

                <!-- Botones del menú -->
                <Button Content="Dashboard"
                        Style="{StaticResource SidebarButtonStyle}"/>

                <Button Content="Convertir juegos"
                        Style="{StaticResource SidebarButtonStyle}"/>

                <Button Content="Procesar POPS"
                        Style="{StaticResource SidebarButtonStyle}"/>

                <Button Content="Configuración"
                        Style="{StaticResource SidebarButtonStyle}"/>

                <Button Content="Acerca de"
                        Style="{StaticResource SidebarButtonStyle}"/>

            </StackPanel>
        </Border>


        <!-- ========================= -->
        <!--  PANEL PRINCIPAL -->
        <!-- ========================= -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Text="Procesar juegos"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0 0 0 20"/>

            <!-- Contenido principal -->
            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Zona de arrastrar archivos -->
                <Border Grid.Column="0"
                        BorderBrush="#444"
                        BorderThickness="2"
                        CornerRadius="10"
                        Background="#2D2D30"
                        Padding="20"
                        AllowDrop="True">

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10">

                        <TextBlock Text="Arrastra aquí tus BIN / CUE / ISO / VCD"
                                   Foreground="#CCC"
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>

                        <Button Content="Seleccionar archivos"
                                Width="180"
                                Height="40"
                                Background="#0078D4"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>

                </Border>

                <!-- Panel lateral de vista previa -->
                <Border Grid.Column="1"
                        Background="#2D2D30"
                        CornerRadius="10"
                        Padding="15"
                        Margin="20 0 0 0">

                    <StackPanel Spacing="10">

                        <TextBlock Text="Vista previa"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                        <Border Background="#1E1E1E"
                                Height="180"
                                CornerRadius="6"
                                HorizontalAlignment="Center"
                                Width="180">
                            <TextBlock Text="Sin carátula"
                                       Foreground="#777"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Nombre:"
                                   Foreground="#AAA"/>
                        <TextBlock x:Name="PreviewName"
                                   Foreground="White"/>

                        <TextBlock Text="Game ID:"
                                   Foreground="#AAA"/>
                        <TextBlock x:Name="PreviewGameId"
                                   Foreground="White"/>

                        <TextBlock Text="Región:"
                                   Foreground="#AAA"/>
                        <TextBlock x:Name="PreviewRegion"
                                   Foreground="White"/>

                        <TextBlock Text="Tipo:"
                                   Foreground="#AAA"/>
                        <TextBlock x:Name="PreviewType"
                                   Foreground="White"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>


        <!-- ========================= -->
        <!--  STATUS BAR INFERIOR -->
        <!-- ========================= -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="#252526"
                BorderBrush="#333"
                BorderThickness="1,1,0,0"
                Padding="10 0">

            <DockPanel>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            Spacing="10">

                    <TextBlock x:Name="StatusText"
                               Text="Listo"
                               Foreground="#CCC"/>

                    <TextBlock Text="●"
                               Foreground="#0078D4"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="Ver logs"
                        DockPanel.Dock="Right"
                        Background="#333"
                        Foreground="White"
                        BorderThickness="0"
                        Width="80"
                        Height="22"
                        Cursor="Hand"/>

            </DockPanel>

        </Border>


        <!-- ========================= -->
        <!--  ÁREA DE NOTIFICACIONES -->
        <!-- ========================= -->
        <StackPanel x:Name="NotificationArea"
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Top"
                    Margin="0 60 0 0"
                    IsHitTestVisible="False"/>

    </Grid>
</Window>
