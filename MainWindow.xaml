<Window x:Class="POPSManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:POPSManager.Controls"
        xmlns:views="clr-namespace:POPSManager.Views"
        xmlns:ui="clr-namespace:POPSManager.UI.Notifications"
        xmlns:viewModels="clr-namespace:POPSManager.ViewModels"
        Title="POPSManager"
        Width="1200"
        Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <!-- DataContext se asigna en App.xaml.cs, pero también se puede definir aquí para diseño -->
    <Window.DataContext>
        <viewModels:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource Brush.Panel}"
                Padding="12"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <TextBlock Text="POPSManager"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right">
                    <Button Content="⚙"
                            Width="32" Height="32"
                            Margin="0 0 10 0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenSettingsCommand}"/>
                    <Button Content="❔"
                            Width="32" Height="32"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenAboutCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- SIDEBAR -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="10">
                <TextBlock Text="Menú"
                           Foreground="{StaticResource Brush.TextMuted}"
                           FontSize="14"
                           Margin="4 0 0 4"/>

                <Button Content="Dashboard"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0 0 0 10"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Dashboard"/>

                <Button Content="Convertir juegos"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0 0 0 10"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Convert"/>

                <Button Content="Procesar POPS"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0 0 0 10"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="ProcessPops"/>

                <Button Content="Cheats"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0 0 0 10"
                        Command="{Binding OpenCheatsSettingsCommand}"/>

                <Button Content="Configuración"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0 0 0 10"
                        Command="{Binding OpenSettingsCommand}"/>

                <Button Content="Acerca de"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding OpenAboutCommand}"/>
            </StackPanel>
        </Border>

        <!-- CONTENIDO PRINCIPAL (vistas dinámicas) -->
        <ContentControl Grid.Row="1" Grid.Column="1"
                        Margin="20"
                        Content="{Binding CurrentView}"/>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1,1,0,0"
                Padding="10 0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                           Foreground="{StaticResource Brush.TextSecondary}"/>
            </DockPanel>
        </Border>

        <!-- NOTIFICATION HOST -->
        <ui:NotificationHost x:Name="Notifier"
                             Grid.Row="0"
                             Grid.ColumnSpan="2"
                             VerticalAlignment="Top"
                             HorizontalAlignment="Right"
                             Margin="0 60 20 0"
                             Width="350"/>

        <!-- PROGRESS PANEL (ahora con bindings completos) -->
        <controls:ProgressPanel Grid.Row="1"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0 10 10 0"
                                Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                ProgressValue="{Binding ProgressValue}"
                                StatusText="{Binding ProgressStatusText}"
                                IsSpinnerActive="{Binding IsProgressVisible}"/>
    </Grid>
</Window>