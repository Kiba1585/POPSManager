<Window x:Class="POPSManager.UI.Windows.CheatSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="520"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Background}"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="{Binding TitleText}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   Margin="0 0 0 20"/>

        <!-- Contenido -->
        <StackPanel Grid.Row="1" Margin="0 10 0 10" VerticalAlignment="Top">

            <!-- Modo de generación -->
            <TextBlock Text="{Binding ModeLabel}"
                       FontWeight="Bold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0 0 0 8"/>

            <ComboBox x:Name="ModeCombo"
                      Width="300"
                      SelectedIndex="1"
                      Margin="0 0 0 20">
                <ComboBoxItem Content="{Binding ModeDisabled}"/>
                <ComboBoxItem Content="{Binding ModeAutoPal}"/>
                <ComboBoxItem Content="{Binding ModeAsk}"/>
                <ComboBoxItem Content="{Binding ModeManual}"/>
            </ComboBox>

            <!-- Opciones avanzadas -->
            <TextBlock Text="{Binding AdvancedLabel}"
                       FontWeight="Bold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0 0 0 8"/>

            <CheckBox x:Name="AutoFixesCheck"
                      Content="{Binding AutoFixesText}"
                      Margin="0 4"/>

            <CheckBox x:Name="EngineFixesCheck"
                      Content="{Binding EngineFixesText}"
                      Margin="0 4"/>

            <CheckBox x:Name="HeuristicFixesCheck"
                      Content="{Binding HeuristicFixesText}"
                      Margin="0 4"/>

            <CheckBox x:Name="DatabaseFixesCheck"
                      Content="{Binding DatabaseFixesText}"
                      Margin="0 4"/>

            <CheckBox x:Name="CustomCheatsCheck"
                      Content="{Binding CustomCheatsText}"
                      Margin="0 4"/>

        </StackPanel>

        <!-- Botones -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 20 0 0">

            <Button Content="{Binding CancelButtonText}"
                    Width="100"
                    Margin="0 0 10 0"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click"/>

            <Button Content="{Binding SaveButtonText}"
                    Width="120"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>