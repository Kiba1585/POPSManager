<Window x:Class="POPSManager.UI.Windows.GameSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="520"
        Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Background}"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewModels:GameSelectorViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding TitleText}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   Margin="0 0 0 20"/>

        <ListBox ItemsSource="{Binding Games}"
                 SelectedItem="{Binding SelectedGame}"
                 Grid.Row="1"
                 BorderBrush="{StaticResource Brush.Border}"
                 BorderThickness="1"
                 Background="{StaticResource Brush.Panel}"
                 Foreground="{StaticResource Brush.TextPrimary}"
                 SelectionMode="Single"
                 DisplayMemberPath="Name"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 20 0 0">

            <Button Content="{Binding CancelButtonText}"
                    Width="100"
                    Margin="0 0 10 0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}"/>

            <Button Content="{Binding EditButtonText}"
                    Width="140"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding EditCommand}"/>
        </StackPanel>
    </Grid>
</Window>