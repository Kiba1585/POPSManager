<Window x:Class="POPSManager.UI.Windows.CheatEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="700"
        Height="650"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Background}"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewModels:CheatEditorViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding TitleText}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   Margin="0 0 0 20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox ItemsSource="{Binding Cheats}"
                     SelectedItem="{Binding SelectedCheat}"
                     Grid.Column="0"
                     BorderBrush="{StaticResource Brush.Border}"
                     BorderThickness="1"
                     Background="{StaticResource Brush.Panel}"
                     Foreground="{StaticResource Brush.TextPrimary}"
                     SelectionMode="Single"
                     Margin="0 0 10 0"
                     DisplayMemberPath="Name"/>

            <StackPanel Grid.Column="1" Margin="10 0 0 0">
                <TextBlock Text="{Binding SelectedCheat.Name}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           Margin="0 0 0 10"/>

                <TextBlock Text="{Binding SelectedCheat.Category, StringFormat='Categoría: {0}'}"
                           FontSize="14"
                           Foreground="{StaticResource Brush.TextMuted}"
                           Margin="0 0 0 10"/>

                <TextBlock Text="{Binding SelectedCheat.Description}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           Margin="0 0 0 20"/>

                <CheckBox IsChecked="{Binding IsCheatEnabled}"
                          Content="{Binding EnableCheatText}"
                          Margin="0 0 0 20"
                          FontSize="14"
                          Foreground="{StaticResource Brush.TextPrimary}"/>

                <StackPanel Orientation="Horizontal" Margin="0 20 0 0">
                    <Button Content="{Binding AddCustomCheatText}"
                            Width="200"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddCustomCheatCommand}"/>

                    <Button Content="{Binding DeleteCheatText}"
                            Width="150"
                            Margin="10 0 0 0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding DeleteCustomCheatCommand}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 20 0 0">

            <Button Content="{Binding CancelButtonText}"
                    Width="100"
                    Margin="0 0 10 0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}"/>

            <Button Content="{Binding SaveButtonText}"
                    Width="120"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</Window>