<Window x:Class="POPSManager.UI.Windows.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:POPSManager.UI.Progress"
        Title="Progreso"
        Width="600"
        Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Background}"
        ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type local:GameProgressItem}">
                    <Border Margin="10"
                            Padding="15"
                            Background="{StaticResource Brush.Panel}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="6">

                        <StackPanel>

                            <TextBlock Text="{Binding Title}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}"/>

                            <ProgressBar Value="{Binding Progress}"
                                         Height="18"
                                         Margin="0 10 0 5"/>

                            <TextBlock Text="{Binding Status}"
                                       FontSize="14"
                                       Foreground="{StaticResource Brush.TextSecondary}"/>

                        </StackPanel>

                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Window>
