<UserControl x:Class="POPSManager.UI.Inspectors.InspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:POPSManager.ViewModels"
             Background="#1A1A1A">

    <UserControl.DataContext>
        <viewModels:InspectorViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Inspector de Archivo"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0 0 0 20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">

                <!-- INFO GENERAL -->
                <Expander Header="Información General"
                          Background="#222"
                          Foreground="White"
                          FontWeight="Bold"
                          Padding="10"
                          IsExpanded="True"
                          Margin="0 0 0 18">
                    <StackPanel Margin="10">
                        <TextBlock Text="Ruta:" Foreground="#4FC3F7"/>
                        <TextBlock Text="{Binding FilePath}" Foreground="White" Margin="0 0 0 10"/>

                        <TextBlock Text="Tamaño:" Foreground="#4FC3F7"/>
                        <TextBlock Text="{Binding FileSize}" Foreground="White" Margin="0 0 0 10"/>

                        <TextBlock Text="Tipo:" Foreground="#4FC3F7"/>
                        <TextBlock Text="{Binding FileType}" Foreground="White"/>
                    </StackPanel>
                </Expander>

                <!-- ID + REGIÓN -->
                <Expander Header="Identificación"
                          Background="#222"
                          Foreground="White"
                          FontWeight="Bold"
                          Padding="10"
                          IsExpanded="True"
                          Margin="0 0 0 18">
                    <StackPanel Margin="10">
                        <TextBlock Text="Game ID:" Foreground="#81C784"/>
                        <TextBlock Text="{Binding GameId}" Foreground="#FFEB3B" FontWeight="Bold" Margin="0 0 0 10"/>

                        <TextBlock Text="Región:" Foreground="#81C784"/>
                        <TextBlock Text="{Binding Region}" Foreground="#FFEB3B" FontWeight="Bold"/>
                    </StackPanel>
                </Expander>

                <!-- SYSTEM.CNF -->
                <Expander Header="SYSTEM.CNF"
                          Background="#222"
                          Foreground="White"
                          FontWeight="Bold"
                          Padding="10"
                          IsExpanded="True"
                          Margin="0 0 0 18">
                    <Border Background="#111" CornerRadius="6" Margin="10">
                        <TextBox Text="{Binding SystemCnf, Mode=OneWay}"
                                 Foreground="White"
                                 Background="#111"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 Height="180"
                                 TextWrapping="Wrap"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto"
                                 IsReadOnly="True"/>
                    </Border>
                </Expander>

                <!-- ARCHIVOS INTERNOS -->
                <Expander Header="Archivos Internos"
                          Background="#222"
                          Foreground="White"
                          FontWeight="Bold"
                          Padding="10"
                          IsExpanded="False"
                          Margin="0 0 0 18">
                    <Border Background="#111" CornerRadius="6" Margin="10">
                        <ListView ItemsSource="{Binding InternalFiles}"
                                  Background="#111"
                                  Foreground="White"
                                  BorderThickness="0"
                                  Height="250">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Nombre" Width="250" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="LBA" Width="80" DisplayMemberBinding="{Binding Lba}"/>
                                    <GridViewColumn Header="Tamaño" Width="120" DisplayMemberBinding="{Binding Size}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Expander>

                <!-- PVD -->
                <Expander Header="Primary Volume Descriptor (PVD)"
                          Background="#222"
                          Foreground="White"
                          FontWeight="Bold"
                          Padding="10"
                          IsExpanded="False">
                    <StackPanel Margin="10">
                        <TextBlock Text="{Binding PvdInfo}" Foreground="White"/>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>