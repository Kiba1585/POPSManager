<UserControl x:Class="POPSManager.UI.Inspectors.InspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#1A1A1A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <TextBlock Text="Inspector de Archivo"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0 0 0 20"/>

        <!-- CONTENIDO -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Spacing="20">

                <!-- INFO GENERAL -->
                <Border Background="#222" Padding="15" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Información General"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#4FC3F7"/>

                        <TextBlock Text="{Binding FilePath}" Foreground="White" Margin="0 5 0 0"/>
                        <TextBlock Text="{Binding FileSize}" Foreground="White"/>
                        <TextBlock Text="{Binding FileType}" Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- ID + REGIÓN -->
                <Border Background="#222" Padding="15" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Identificación"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#81C784"/>

                        <TextBlock Text="Game ID:" Foreground="White"/>
                        <TextBlock Text="{Binding GameId}" Foreground="#FFEB3B" FontWeight="Bold"/>

                        <TextBlock Text="Región:" Foreground="White" Margin="0 10 0 0"/>
                        <TextBlock Text="{Binding Region}" Foreground="#FFEB3B" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- SYSTEM.CNF -->
                <Border Background="#222" Padding="15" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="SYSTEM.CNF"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#F06292"/>

                        <TextBox Text="{Binding SystemCnf}"
                                 Foreground="White"
                                 Background="#111"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 Height="150"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>

                <!-- ARCHIVOS INTERNOS -->
                <Border Background="#222" Padding="15" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Archivos Internos"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#BA68C8"/>

                        <ListView ItemsSource="{Binding InternalFiles}"
                                  Background="#111"
                                  Foreground="White"
                                  BorderThickness="0"
                                  Height="200">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Nombre" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="LBA" Width="80" DisplayMemberBinding="{Binding Lba}"/>
                                    <GridViewColumn Header="Tamaño" Width="100" DisplayMemberBinding="{Binding Size}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- PVD -->
                <Border Background="#222" Padding="15" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Primary Volume Descriptor (PVD)"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FFD54F"/>

                        <TextBlock Text="{Binding PvdInfo}" Foreground="White"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
