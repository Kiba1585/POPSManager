<UserControl x:Class="POPSManager.UI.GameCoverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="260" Width="200"
             DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Border CornerRadius="8" BorderBrush="#444" BorderThickness="1" Padding="6">
        <StackPanel>

            <Image Height="200"
                   Stretch="UniformToFill"
                   Margin="0,0,0,8"
                   Source="{Binding CoverImageSource, FallbackValue={StaticResource PlaceholderImage}}"/>

            <TextBlock FontSize="14"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Foreground="White"
                       Text="{Binding GameTitle}"/>

            <TextBlock FontSize="12"
                       Foreground="#CCC"
                       Text="{Binding GameId, StringFormat='ID: {0}'}"/>

        </StackPanel>
    </Border>
</UserControl>