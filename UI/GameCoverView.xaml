<UserControl x:Class="POPSManager.UI.GameCoverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="260" Width="200">

    <Border CornerRadius="8" BorderBrush="#444" BorderThickness="1" Padding="6">
        <StackPanel>

            <!-- Imagen de portada -->
            <Image x:Name="CoverImage"
                   Height="200"
                   Stretch="UniformToFill"
                   Margin="0,0,0,8"
                   Source="/POPSManager;component/Assets/placeholder.jpg"/>

            <!-- Título -->
            <TextBlock x:Name="GameTitle"
                       FontSize="14"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Foreground="White"/>

            <!-- ID -->
            <TextBlock x:Name="GameId"
                       FontSize="12"
                       Foreground="#CCC"/>

        </StackPanel>
    </Border>
</UserControl>
