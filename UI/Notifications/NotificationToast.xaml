<UserControl x:Class="POPSManager.UI.Notifications.NotificationToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="320"
             Opacity="0">

    <Border x:Name="Root"
            CornerRadius="8"
            Padding="12"
            Margin="0 0 0 10"
            Background="#222"
            BorderThickness="1"
            BorderBrush="#444"
            SnapsToDevicePixels="True">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
            </Grid.ColumnDefinitions>

            <!-- ICONO -->
            <TextBlock x:Name="Icon"
                       FontSize="20"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="White"/>

            <!-- TEXTO -->
            <StackPanel Grid.Column="1" Margin="10 0">
                <TextBlock x:Name="Title"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="White"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="Message"
                           FontSize="13"
                           Foreground="#DDD"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- BOTÓN CERRAR -->
            <Button Grid.Column="2"
                    Content="✕"
                    Width="26"
                    Height="26"
                    Background="#333"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</UserControl>
