<Application x:Class="POPSManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- ===================================================== -->
                <!--  PALETA DE COLORES (DEBE IR PRIMERO SIEMPRE)          -->
                <!-- ===================================================== -->
                <ResourceDictionary Source="Resources/Colors.xaml"/>

                <!-- ===================================================== -->
                <!--  ESTILOS BASE (TextBlock, Grid, etc.)                 -->
                <!-- ===================================================== -->
                <ResourceDictionary Source="Resources/Styles.xaml"/>

                <!-- ===================================================== -->
                <!--  SOMBRAS Y TARJETAS (depende de Colors)               -->
                <!-- ===================================================== -->
                <ResourceDictionary Source="Resources/Shadows.xaml"/>
                <ResourceDictionary Source="Resources/Cards.xaml"/>

                <!-- ===================================================== -->
                <!--  BOTONES (depende de Styles + Colors)                 -->
                <!-- ===================================================== -->
                <ResourceDictionary Source="Resources/Buttons.xaml"/>

                <!-- ===================================================== -->
                <!--  SIDEBAR / MENÚ LATERAL                               -->
                <!-- ===================================================== -->
                <ResourceDictionary Source="Resources/SidebarStyles.xaml"/>

                <!-- ===================================================== -->
                <!--  CONTROLES ESPECIALES (ProgressPanel, LogsPanel)      -->
                <!-- ===================================================== -->
                <ResourceDictionary Source="Resources/ProgressPanel.xaml"/>
                <ResourceDictionary Source="Resources/LogsPanel.xaml"/>

                <!-- ===================================================== -->
                <!--  TOASTS / NOTIFICACIONES (depende de Colors + Styles) -->
                <!-- ===================================================== -->
                <ResourceDictionary Source="Resources/Toasts.xaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>

    </Application.Resources>

</Application>
