<Application x:Class="POPSManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- =============================== -->
                <!--   PALETA DE COLORES            -->
                <!-- =============================== -->
                <ResourceDictionary Source="Resources/Colors.xaml"/>

                <!-- =============================== -->
                <!--   ESTILOS BASE (TextBlock, etc.) -->
                <!-- =============================== -->
                <ResourceDictionary Source="Resources/Styles.xaml"/>

                <!-- =============================== -->
                <!--   BOTONES                      -->
                <!-- =============================== -->
                <ResourceDictionary Source="Resources/Buttons.xaml"/>

                <!-- =============================== -->
                <!--   TARJETAS, BORDES, SOMBRAS    -->
                <!-- =============================== -->
                <ResourceDictionary Source="Resources/Cards.xaml"/>
                <ResourceDictionary Source="Resources/Shadows.xaml"/>

                <!-- =============================== -->
                <!--   TOASTS (animaciones + estilos) -->
                <!-- =============================== -->
                <ResourceDictionary Source="Resources/Toasts.xaml"/>

                <!-- =============================== -->
                <!--   SIDEBAR / MENÚ LATERAL       -->
                <!-- =============================== -->
                <ResourceDictionary Source="Resources/SidebarStyles.xaml"/>

                <!-- =============================== -->
                <!--   ESTILOS DE CONTROLES EXTRA   -->
                <!-- =============================== -->
                <ResourceDictionary Source="Resources/ProgressPanel.xaml"/>
                <ResourceDictionary Source="Resources/LogsPanel.xaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>

    </Application.Resources>

</Application>
