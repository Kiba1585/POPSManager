<Application x:Class="POPSManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- ══════════════════════════════════════
                     TEMA PRINCIPAL (colores, botones, cards, tipografía)
                     Theme.xaml contiene TODO lo que antes estaba en
                     Colors.xaml, Styles.xaml, Cards.xaml, Buttons.xaml
                     ══════════════════════════════════════ -->
                <ResourceDictionary Source="Styles/Theme.xaml"/>

                <!-- ══════════════════════════════════════
                     COMPONENTES ESPECÍFICOS
                     ══════════════════════════════════════ -->
                <ResourceDictionary Source="Styles/Shadows.xaml"/>
                <ResourceDictionary Source="Styles/SidebarStyles.xaml"/>
                <ResourceDictionary Source="Styles/ProgressPanel.xaml"/>
                <ResourceDictionary Source="Styles/LogsPanel.xaml"/>
                <ResourceDictionary Source="Styles/Toasts.xaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
