<Application x:Class="POPSManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:POPSManager.Converters"
             xmlns:automation="clr-namespace:POPSManager.Logic.Automation"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ══════════════════════════════════════
                 CONVERTIDORES GLOBALES
                 ══════════════════════════════════════ -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />

            <!-- ══════════════════════════════════════
                 LISTA DE VALORES PARA AutoBehavior (ComboBox)
                 ══════════════════════════════════════ -->
            <ObjectDataProvider x:Key="AutoBehaviorValues"
                                MethodName="GetValues"
                                ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="automation:AutoBehavior" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>

            <ResourceDictionary.MergedDictionaries>

                <!-- ══════════════════════════════════════
                     TEMA PRINCIPAL (colores, botones, cards, tipografía)
                     Theme.xaml contiene TODO lo que antes estaba en
                     Colors.xaml, Styles.xaml, Cards.xaml, Buttons.xaml
                     ══════════════════════════════════════ -->
                <ResourceDictionary Source="Styles/Theme.xaml"/>

                <!-- ══════════════════════════════════════
                     COMPONENTES ESPECÍFICOS
                     ══════════════════════════════════════ -->
                <ResourceDictionary Source="Styles/Shadows.xaml"/>
                <ResourceDictionary Source="Styles/SidebarStyles.xaml"/>
                <!-- Eliminamos ProgressPanel.xaml porque ahora es un UserControl en Controls/ -->
                <!-- <ResourceDictionary Source="Styles/ProgressPanel.xaml"/> -->
                <ResourceDictionary Source="Styles/LogsPanel.xaml"/>
                <ResourceDictionary Source="Styles/Toasts.xaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>